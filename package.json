{
  "name": "contract_placements",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "cross-env PORT=3000 next dev",
    "demo": "npm run dev",
    "build": "cross-env NODE_ENV=production next build",
    "prod:build": "npm run build",
    "start": "cross-env PORT=3001 next start",
    "prod:start": "npm run start",
    "lint": "eslint",
    "test": "vitest run",
    "e2e": "playwright test",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "seed": "npm run prisma:generate && prisma db push && tsx scripts/seed.ts",
    "seed:demo-policy": "tsx scripts/normaliseDemoData.ts",
    "migrate:non-example-to-prod": "tsx scripts/moveNonExampleCandidatesToProd.ts",
    "cleanup:smoke": "tsx scripts/cleanupSmokeData.ts",
    "backfill:opportunity": "tsx scripts/backfillOpportunityId.ts",
    "dedupe:opportunity": "tsx scripts/dedupeApplicationsByOpportunity.ts",
    "candidate:confirm-roles": "node scripts/generateCandidateRoleConfirmationDrafts.cjs",
    "inbox:process-replies": "node scripts/processInboxReplies.cjs",
    "inbox:process-replies:apply": "node scripts/processInboxReplies.cjs --apply",
    "inbox:send-todays-drafts": "node scripts/sendTodaysDrafts.cjs",
    "inbox:install-task": "schtasks /Create /XML scripts\\inbox-agent-task.xml /TN \"\\ContractPlacements\\InboxReplyAgent\" /F",
    "prepare": "husky install"
  },
  "dependencies": {
    "@azure/msal-browser": "^5.6.3",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.2.2",
    "@pdf-lib/fontkit": "^1.1.1",
    "@prisma/client": "^6.19.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tanstack/react-query": "^5.99.0",
    "@tanstack/react-virtual": "^3.13.23",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.7.0",
    "mammoth": "^1.12.0",
    "next": "16.2.2",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.4",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^1.1.4",
    "pdfjs-dist": "^5.6.205",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.72.0",
    "tailwind-merge": "^3.5.0",
    "xlsx": "^0.18.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.7.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "cross-env": "^7.0.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.2",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "lint-staged": "^16.4.0",
    "playwright": "^1.59.1",
    "prisma": "^6.19.3",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,css,md}": [
      "eslint --fix"
    ]
  }
}
