{
  "name": "contract_placements",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "cross-env PORT=3000 next dev",
    "demo": "npm run dev",
    "build": "cross-env NODE_ENV=production next build",
    "prod:build": "npm run build",
    "start": "cross-env PORT=3001 next start",
    "prod:start": "npm run start",
    "lint": "eslint",
    "test": "vitest",
    "e2e": "playwright test",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "seed": "npm run prisma:generate && prisma db push && tsx scripts/seed.ts",
    "cleanup:smoke": "tsx scripts/cleanupSmokeData.ts",
    "backfill:opportunity": "tsx scripts/backfillOpportunityId.ts",
    "dedupe:opportunity": "tsx scripts/dedupeApplicationsByOpportunity.ts",
    "prepare": "husky install",
    "seed:demo-policy": "tsx scripts/normaliseDemoData.ts",
    "migrate:non-example-to-prod": "tsx scripts/moveNonExampleCandidatesToProd.ts"
  },
  "dependencies": {
    "@azure/msal-browser": "^4.10.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^9.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^3.9.1",
    "@prisma/client": "^6.2.1",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-switch": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "mammoth": "^1.11.0",
    "next": "16.1.6",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.1",
    "pdf-parse": "^1.1.1",
    "pdfjs-dist": "^5.4.624",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.54.2",
    "tailwind-merge": "^2.6.0",
    "xlsx": "^0.18.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.3.4",
    "babel-plugin-react-compiler": "1.0.0",
    "cross-env": "^7.0.3",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "husky": "^9.1.6",
    "jsdom": "^25.0.1",
    "lint-staged": "^15.3.0",
    "playwright": "^1.49.1",
    "prisma": "^6.2.1",
    "tailwindcss": "^4",
    "tsx": "^4.19.2",
    "typescript": "^5",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,css,md}": [
      "eslint --fix"
    ]
  }
}
