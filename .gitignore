# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/
/.next-run/
/.next-run-prod/
/.next-run-demo/
/.next-authfix/

# local test/build artefacts
/test-results/
*.db
*.db-shm
*.db-wal
temp_upload_test.csv
data/github-token.txt

# secrets — never commit these
.secrets/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
.secrets/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
